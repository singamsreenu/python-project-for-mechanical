 
class Solution: 
    def findMissingAndRepeatedValues(self, grid: List[List[int]]) -> List[int]: 
        n = len(grid) 
        size = n * n 
         
        # Frequency array (1-indexed) 
        freq = [0] * (size + 1) 
         
        # Count occurrences 
        for row in grid: 
            for num in row: 
                freq[num] += 1 
         
        a = b = 0 
        for num in range(1, size + 1): 
            if freq[num] == 2: 
                a = num 
            elif freq[num] == 0: 
                b = num 
         
        return [a, b]
