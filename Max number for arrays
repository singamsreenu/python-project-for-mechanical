def maxNumber(nums1, nums2, k):
    # Get max subsequence of length k
    def getMax(nums, k):
        stack = []
        drop = len(nums) - k
        
        for num in nums:
            while drop and stack and stack[-1] < num:
                stack.pop()
                drop -= 1
            stack.append(num)
        
        return stack[:k]

    # Merge two arrays into max number
    def merge(a, b):
        result = []
        while a or b:
            if a > b:
                result.append(a.pop(0))
            else:
                result.append(b.pop(0))
        return result

    max_result = []
    
    # Try all splits
    for i in range(k + 1):
        if i <= len(nums1) and (k - i) <= len(nums2):
            part1 = getMax(nums1, i)
            part2 = getMax(nums2, k - i)
            candidate = merge(part1[:], part2[:])
            max_result = max(max_result, candidate)

    return max_result
