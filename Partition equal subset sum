def canPartition(nums):
    total = sum(nums)
    
    # If total is odd, cannot split equally
    if total % 2 != 0:
        return False
    
    target = total // 2
    
    # DP set to store possible sums
    dp = set()
    dp.add(0)
    
    for num in nums:
        new_dp = dp.copy()
        for s in dp:
            if s + num == target:
                return True
            new_dp.add(s + num)
        dp = new_dp
    
    return target in dp
