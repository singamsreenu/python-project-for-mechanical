from typing import List

class Solution:
    def alternatingSubsequence(self, words: List[str], groups: List[int]) -> List[str]:
        subsequence = []
        last_group = None
        
        for w, g in zip(words, groups):
            if last_group is None or g != last_group:
                subsequence.append(w)
                last_group = g
        
        return subsequence
